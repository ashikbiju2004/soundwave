{
  "name": "soundwave",
  "version": "1.0.0",
  "description": "Spotify-like music platform — upload, stream and sync your music",
  "private": true,
  "scripts": {
    "dev":          "npx serve . --listen 3000 --cors",
    "build":        "echo 'No build step required — pure HTML/CSS/JS'",
    "cap:sync":     "npx cap sync",
    "cap:android":  "npx cap open android",
    "cap:ios":      "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios":     "npx cap run ios",
    "cap:build:android": "npx cap build android",
    "deploy":       "netlify deploy --dir . --prod"
  },
  "dependencies": {
    "@capacitor/android":    "^6.0.0",
    "@capacitor/app":        "^6.0.0",
    "@capacitor/core":       "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics":    "^6.0.0",
    "@capacitor/ios":        "^6.0.0",
    "@capacitor/keyboard":   "^6.0.0",
    "@capacitor/network":    "^6.0.0",
    "@capacitor/share":      "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "netlify-cli":    "^17.0.0",
    "serve":          "^14.0.0"
  },
  "keywords": ["music","player","spotify","pwa","capacitor"],
  "author": "",
  "license": "MIT"
}
